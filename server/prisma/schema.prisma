generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model auth_users {
  name                        String?                       @unique
  email                       String?                       @unique
  emailVerified               DateTime?
  image                       String?
  passwordHash                String?                       @db.VarChar(60)
  createdAt                   DateTime                      @default(now())
  updatedAt                   DateTime
  id                          Int                           @id @default(autoincrement())
  created_by                  Int?
  is_deleted                  Boolean                       @default(false)
  roleId                      Int
  roles                       roles                         @relation(fields: [roleId], references: [id])
  dictionary_filter_templates dictionary_filter_templates[]
}

model jp_img {
  id         BigInt    @id @default(autoincrement())
  w          BigInt
  h          BigInt
  livel      BigInt    @default(3)
  t_8x8      String
  t_16x16    String
  sorc       Bytes
  use_number String
  tags       String
  add_date   DateTime? @db.Date
  add_user   String    @default("") @db.VarChar(256)
}

model language {
  id               Int             @id(map: "Language_pkey") @default(autoincrement())
  code             String          @unique(map: "Language_code_key") @db.VarChar(8)
  name             String          @db.VarChar(64)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime
  word_replace_map Json?
  opred_v          opred_v[]
  pending_words    pending_words[]
  word_v           word_v[]
}

model log_coment {
  id          BigInt    @id @default(autoincrement())
  user        String    @default("") @db.VarChar(64)
  id_opr      BigInt
  text_coment String    @default("") @db.VarChar(256)
  add_data    DateTime? @db.Date

  @@index([id_opr])
}

model opred_tags {
  opredId BigInt
  tagId   Int
  addedAt DateTime @default(now())
  addedBy Int?
  opred_v opred_v  @relation(fields: [opredId], references: [id], onDelete: Cascade)
  tags    tags     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([opredId, tagId])
  @@index([tagId])
}

model opred_v {
  id                                        BigInt                 @id @default(autoincrement())
  word_id                                   BigInt                 @default(-1)
  text_opr                                  String                 @default("") @db.VarChar(255)
  length                                    Int?                   @db.SmallInt
  end_date                                  DateTime?              @db.Timestamp(6)
  tema                                      BigInt                 @default(0)
  difficulty                                Int                    @default(1) @db.SmallInt
  id_file                                   BigInt                 @default(-1)
  use                                       Int                    @default(1) @db.SmallInt
  user_add                                  String                 @default("") @db.VarChar(32)
  create_at                                 DateTime?              @default(now()) @db.Timestamp(6)
  edit_user                                 String                 @default("") @db.VarChar(32)
  update_at                                 DateTime?              @db.Timestamp(6)
  coment                                    String                 @default("") @db.VarChar(512)
  set_reg                                   BigInt                 @default(3)
  data_set                                  DateTime?              @db.Timestamp(6)
  user_set                                  String                 @default("") @db.VarChar(255)
  go_flag                                   Int                    @default(0) @db.SmallInt
  is_deleted                                Boolean                @default(false)
  langId                                    Int
  approvedBy                                Int?                   @db.SmallInt
  createBy                                  Int?                   @db.SmallInt
  updateBy                                  Int?                   @db.SmallInt
  text_updated_at                           DateTime?              @db.Timestamp(6)
  edition_opred_stat                        edition_opred_stat[]
  issue_opred_usage                         issue_opred_usage[]
  opred_tags                                opred_tags[]
  difficulty_opred_v_difficultyTodifficulty difficulty             @relation("opred_v_difficultyTodifficulty", fields: [difficulty], references: [id])
  language                                  language               @relation(fields: [langId], references: [id])
  word_v                                    word_v                 @relation(fields: [word_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "word_fkey")
  pending_descriptions                      pending_descriptions[]

  @@index([langId], map: "idx_opred_v__langId")
  @@index([langId, is_deleted, end_date], map: "idx_opred_v__langId_is_deleted_end_date")
  @@index([word_id, is_deleted])
}

model pending_descriptions {
  id              BigInt        @id @default(autoincrement())
  pendingWordId   BigInt
  description     String        @db.VarChar(1024)
  note            String        @db.VarChar(512)
  status          PendingStatus @default(PENDING)
  is_deleted      Boolean       @default(false)
  approvedOpredId BigInt?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  langId          Int           @default(3)
  difficulty      Int           @default(1) @db.SmallInt
  end_date        DateTime?     @db.Timestamp(6)
  approvedBy      Int?          @db.SmallInt
  createBy        Int?          @db.SmallInt
  updateBy        Int?          @db.SmallInt
  opred_v         opred_v?      @relation(fields: [approvedOpredId], references: [id])
  pending_words   pending_words @relation(fields: [pendingWordId], references: [id], onDelete: Cascade)

  @@index([approvedOpredId], map: "idx_pending_descriptions__approvedOpredId")
  @@index([status, createdAt], map: "idx_pending_descriptions__status_createdAt")
  @@index([pendingWordId])
}

model pending_words {
  id                   BigInt                 @id @default(autoincrement())
  word_text            String                 @db.VarChar(255)
  length               Int                    @db.SmallInt
  langId               Int
  createdAt            DateTime               @default(now())
  is_deleted           Boolean                @default(false)
  note                 String                 @db.VarChar(512)
  updatedAt            DateTime
  status               PendingStatus          @default(PENDING)
  targetWordId         BigInt?
  approvedBy           Int?                   @db.SmallInt
  createBy             Int?                   @db.SmallInt
  updateBy             Int?                   @db.SmallInt
  pending_descriptions pending_descriptions[]
  language             language               @relation(fields: [langId], references: [id])
  word_v               word_v?                @relation(fields: [targetWordId], references: [id])

  @@index([status, createdAt], map: "idx_pending_words__status_createdAt")
  @@index([langId, word_text])
  @@index([targetWordId])
}

model permissions {
  id               Int                @id @default(autoincrement())
  code             String             @unique @db.VarChar(64)
  description      String?            @db.VarChar(255)
  role_permissions role_permissions[]
}

model role_permissions {
  roleId       Int
  permissionId Int
  permissions  permissions @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  roles        roles       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model roles {
  id               Int                @id @default(autoincrement())
  code             Role               @unique
  auth_users       auth_users[]
  role_permissions role_permissions[]
}

model shablons {
  id       BigInt @id @default(autoincrement())
  w        BigInt @default(0)
  h        BigInt @default(0)
  mask     String
  foto     BigInt @default(0)
  bin_data Bytes
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model tags {
  id         Int          @id @default(autoincrement())
  name       String       @db.VarChar(255)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime
  opred_tags opred_tags[]
}

model user {
  id       BigInt    @id @default(autoincrement())
  name     String    @db.VarChar(255)
  password String    @db.VarChar(9)
  menu     String    @default("menu_admin") @db.VarChar(255)
  fio      String    @db.VarChar(255)
  pamd     String    @db.VarChar(64)
  end_free DateTime? @db.Date
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model word_v {
  id                BigInt              @id @default(autoincrement())
  word_text         String              @db.VarChar(255)
  length            Int                 @db.SmallInt
  file_id           BigInt              @default(-1)
  user_add          String              @default("system") @db.VarChar(255)
  create_at         DateTime?           @default(now()) @db.Timestamp(6)
  using             Int                 @default(1) @db.SmallInt
  korny             String
  data_set          DateTime?           @db.Timestamp(6)
  user_set          String              @default("") @db.VarChar(255)
  go_flag           Int                 @default(0) @db.SmallInt
  is_deleted        Boolean             @default(false)
  langId            Int
  approvedBy        Int?                @db.SmallInt
  createBy          Int?                @db.SmallInt
  updateBy          Int?                @db.SmallInt
  update_at         DateTime?           @db.Timestamp(6)
  word_text_norm    String?             @db.VarChar(255)
  edition_word_hot_state edition_word_hot_state[]
  edition_word_stat edition_word_stat[]
  issue_word_usage  issue_word_usage[]
  opred_v           opred_v[]
  pending_words     pending_words[]
  language          language            @relation(fields: [langId], references: [id])

  @@index([langId], map: "idx_word_v__langId")
  @@index([langId, word_text], map: "idx_word_v__langId_word_text")
  @@index([is_deleted])
  @@index([langId, is_deleted, word_text], map: "idx_word_v_lang_del_text")
}

model dictionary_filter_templates {
  id              Int         @id @default(autoincrement())
  name            String      @db.VarChar(120)
  language        String      @db.VarChar(8)
  query           String?     @db.VarChar(255)
  scope           String      @default("word") @db.VarChar(8)
  searchMode      String      @default("contains") @db.VarChar(12)
  lenFilterField  String?     @db.VarChar(8)
  lenMin          Int?
  lenMax          Int?
  difficultyMin   Int?
  difficultyMax   Int?
  tagNames        String[]    @default([])
  createdBy       Int?
  is_deleted      Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime
  excludeTagNames String[]    @default([])
  auth_users      auth_users? @relation(fields: [createdBy], references: [id])
  issues          issues[]

  @@index([is_deleted])
  @@index([language])
}

model difficulty {
  id                                     Int       @id @default(autoincrement()) @db.SmallInt
  name                                   String?   @db.VarChar(255)
  create_at                              DateTime? @default(now()) @db.Timestamp(6)
  update_at                              DateTime? @db.Timestamp(6)
  opred_v_opred_v_difficultyTodifficulty opred_v[] @relation("opred_v_difficultyTodifficulty")
}

model edition_opred_stat {
  editionId   Int
  opredId     BigInt
  useCount    Int       @default(0)
  lastIssueId BigInt?
  lastUsedAt  DateTime?
  editions    editions  @relation(fields: [editionId], references: [id], onDelete: Cascade)
  opred_v     opred_v   @relation(fields: [opredId], references: [id], onDelete: Cascade)

  @@id([editionId, opredId])
  @@index([opredId])
}

model edition_word_stat {
  editionId   Int
  wordId      BigInt
  useCount    Int       @default(0)
  lastIssueId BigInt?
  lastUsedAt  DateTime?
  editions    editions  @relation(fields: [editionId], references: [id], onDelete: Cascade)
  word_v      word_v    @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@id([editionId, wordId])
  @@index([wordId])
}

model edition_word_hot_state {
  editionId Int
  wordId    BigInt
  isBanned  Boolean  @default(false)
  updatedAt DateTime @default(now())
  editions  editions @relation(fields: [editionId], references: [id], onDelete: Cascade)
  word_v    word_v   @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@id([editionId, wordId])
  @@index([editionId, isBanned])
  @@index([wordId])
}

model editions {
  id                 Int                  @id @default(autoincrement())
  code               String               @unique @db.VarChar(32)
  name               String               @db.VarChar(255)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  deletedAt          DateTime?
  hidden             Boolean              @default(false)
  edition_word_hot_state edition_word_hot_state[]
  edition_opred_stat edition_opred_stat[]
  edition_word_stat  edition_word_stat[]
  issues             issues[]
}

model issue_numbers {
  id      Int      @id @default(autoincrement())
  label   String   @unique @db.VarChar(64)
  year    Int?     @db.SmallInt
  seq     Int?     @db.SmallInt
  series  String?  @db.VarChar(64)
  sortKey Int?
  issues  issues[]
}

model issue_opred_usage {
  issueId   BigInt
  opredId   BigInt
  useCount  Int      @default(1)
  createdAt DateTime @default(now())
  issues    issues   @relation(fields: [issueId], references: [id], onDelete: Cascade)
  opred_v   opred_v  @relation(fields: [opredId], references: [id], onDelete: Cascade)

  @@id([issueId, opredId])
  @@index([opredId])
}

model issue_word_usage {
  issueId   BigInt
  wordId    BigInt
  useCount  Int      @default(1)
  createdAt DateTime @default(now())
  issues    issues   @relation(fields: [issueId], references: [id], onDelete: Cascade)
  word_v    word_v   @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@id([issueId, wordId])
  @@index([wordId])
}

model issues {
  id                          BigInt                       @id @default(autoincrement())
  editionId                   Int
  issueNumberId               Int
  publishedAt                 DateTime?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime
  deletedAt                   DateTime?
  filterTemplateId            Int?
  hidden                      Boolean                      @default(false)
  issue_opred_usage           issue_opred_usage[]
  issue_word_usage            issue_word_usage[]
  editions                    editions                     @relation(fields: [editionId], references: [id])
  dictionary_filter_templates dictionary_filter_templates? @relation(fields: [filterTemplateId], references: [id])
  issue_numbers               issue_numbers                @relation(fields: [issueNumberId], references: [id])
  scanword_fill_jobs          scanword_fill_jobs[]
  scanword_issue_svg_settings scanword_issue_svg_settings?
  scanword_upload_snapshots   scanword_upload_snapshots?

  @@unique([editionId, issueNumberId])
  @@index([editionId, issueNumberId])
  @@index([filterTemplateId])
}

model scanword_fill_jobs {
  id                 BigInt   @id @default(autoincrement())
  issueId            BigInt
  status             String
  progress           Int      @default(0)
  currentTemplate    String?
  completedTemplates Int?
  totalTemplates     Int?
  error              String?
  outputPath         String?
  outputSize         BigInt?
  templates          Json?
  reviewData         Json?
  options            Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now())
  issues             issues   @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId], map: "idx_scanword_fill_jobs_issue")
}

model scanword_upload_snapshots {
  id           BigInt   @id @default(autoincrement())
  issueId      BigInt   @unique
  templateId   Int?
  templateName String?  @db.VarChar(120)
  fileCount    Int      @default(0)
  errorCount   Int      @default(0)
  neededStats  Json?
  files        Json?
  errors       Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  issues       issues   @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
}

model scanword_svg_fonts {
  id             BigInt   @id @default(autoincrement())
  displayName    String   @db.VarChar(120)
  familyName     String   @db.VarChar(120)
  format         String   @db.VarChar(16)
  mimeType       String   @db.VarChar(64)
  fileName       String   @db.VarChar(255)
  storageRelPath String   @db.VarChar(512)
  sha256         String   @db.VarChar(64)
  sizeBytes      BigInt
  createdBy      Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now())

  issue_settings scanword_issue_svg_settings[]

  @@unique([sha256], map: "scanword_svg_fonts_sha256_key")
  @@index([displayName], map: "idx_scanword_svg_fonts_display")
  @@index([createdAt], map: "idx_scanword_svg_fonts_created")
}

model scanword_issue_svg_settings {
  id               BigInt   @id @default(autoincrement())
  issueId          BigInt   @unique
  clueFontBasePt   Int      @default(9)
  clueFontMinPt    Int      @default(8)
  fontId           BigInt?
  systemFontFamily String   @default("Arial") @db.VarChar(120)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now())

  issues issues             @relation(fields: [issueId], references: [id], onDelete: Cascade)
  font   scanword_svg_fonts? @relation(fields: [fontId], references: [id], onDelete: SetNull)

  @@index([fontId], map: "idx_scanword_issue_svg_settings_font")
}

enum PendingStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  ADMIN
  MANAGER
  USER
  CHIEF_EDITOR_PLUS
  CHIEF_EDITOR
  EDITOR
}
