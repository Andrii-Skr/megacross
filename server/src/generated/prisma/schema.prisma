generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model izd_name {
  id        BigInt    @id @default(autoincrement())
  name      String    @db.VarChar(64)
  redakcia  String    @default("skan") @db.VarChar(16)
  tabl_name String    @db.VarChar(32)
  add_user  String    @db.VarChar(256)
  add_data  DateTime? @default(now()) @db.Timestamptz(6)
}

model number_izd {
  id        BigInt @id @default(autoincrement())
  izd_id    BigInt
  curent_id BigInt
  pub_numb  String @default("пусто") @db.VarChar(64)
}

model opred_v {
  id           BigInt    @id @default(autoincrement())
  word_id      BigInt    @default(-1)
  text_opr     String    @default("") @db.VarChar(255)
  end_date     DateTime? @default(dbgenerated("'2317-01-01'::date")) @db.Date
  lang         String    @default("r") @db.Char(1)
  tema         BigInt    @default(0)
  livel        Int       @default(1) @db.SmallInt
  w1           Int       @default(100) @db.SmallInt
  w2           Int       @default(100) @db.SmallInt
  w3           Int       @default(100) @db.SmallInt
  id_file      BigInt    @default(-1)
  use_for_bild Int       @default(1) @db.SmallInt
  user_add     String    @default("system") @db.VarChar(32)
  add_data     DateTime? @default(dbgenerated("'2011-01-01'::date")) @db.Date
  edit_user    String    @default("") @db.VarChar(32)
  edit_data    DateTime? @default(dbgenerated("'2011-01-01'::date")) @db.Date
  coment       String    @default("") @db.VarChar(512)
  set_reg      BigInt    @default(0)
  user_set     String    @default("") @db.VarChar(255)
  back_id      BigInt    @default(-1)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model publications {
  id          BigInt    @id @default(autoincrement())
  archive     Boolean
  num         String
  seq_num     BigInt
  nameid      BigInt
  region      String?   @default("ALL") @db.VarChar(3)
  level       BigInt?   @default(1)
  repeats     BigInt    @default(1)
  replacement String?
  date        DateTime? @default(now()) @db.Timestamptz(6)
}

model shablon {
  id        BigInt    @id @default(autoincrement())
  w_pazl    BigInt
  h_pazl    BigInt
  foto      Int       @db.SmallInt
  oprd_foto Int       @db.SmallInt
  big_cell  BigInt
  hide_cell Int       @db.SmallInt
  md        String
  type_pazl String
  char_mask String?   @default("") @db.VarChar(1024)
  use_year  Int       @default(0) @db.SmallInt
  use_mon   Int       @default(0) @db.SmallInt
  add_data  DateTime? @db.Timestamptz(6)
}

model shtat {
  id        BigInt  @id @default(autoincrement())
  user_id   BigInt
  shtat     Int     @default(0) @db.SmallInt
  market    BigInt  @default(0)
  scan_bild String
  red_izd   String
  design    BigInt  @default(0)
  lit_baz   Int     @default(0) @db.SmallInt
  admin     Boolean
}

model tems {
  id   BigInt @id @default(autoincrement())
  cod  BigInt
  name String @db.VarChar(512)
}

model user {
  id       BigInt    @id @default(autoincrement())
  name     String    @db.VarChar(255)
  password String    @db.VarChar(9)
  menu     String    @default("menu_admin") @db.VarChar(255)
  fio      String    @db.VarChar(255)
  pamd     String    @db.VarChar(64)
  end_free DateTime? @db.Date
}

model word_group {
  id        BigInt @id @default(autoincrement())
  text_word String @db.VarChar(255)
}

model words_v {
  id          BigInt @id @default(autoincrement())
  word_text   String @db.VarChar(64)
  lingv       String @default("r") @db.VarChar(1)
  key_word    Int    @default(0) @db.SmallInt
  skan        Int    @default(0) @db.SmallInt
  word_group  BigInt @default(0)
  foto        String @default("0") @db.VarChar(1)
  back_id     BigInt @default(-1)
  word_length Int
}
